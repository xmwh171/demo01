<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demofirst.mapper.UserMapper">
    <!-- 基础结果映射（复用） -->
    <resultMap id="UserResultMap" type="com.example.demofirst.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="phone" property="phone"/>
        <result column="enable" property="enable"/>
        <result column="password" property="password"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectUserByCondition" resultMap="UserResultMap">
        SELECT id, username, phone, password,enable, create_time, update_time
        FROM user
        <where>
            <!-- 用户名模糊查询 -->
            <if test="username!= null and username !=''">
               AND username LIKE CONCAT('%',#{username},'%')
            </if>
            <!-- 手机号精准查询 -->
            <if test="phone != null and phone != ''">
                AND phone = #{phone}
            </if>
            <!-- 时间范围查询 -->
            <if test="startTime != null and endTime != null">
                AND create_time BETWEEN #{startTime} AND #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 1. foreach标签：批量查询用户（根据多个ID） -->
    <select id="batchSelectByIds" resultMap="UserResultMap">
        SELECT id, username, age, enable, email, create_time
        FROM user
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        AND enable = 1
    </select>

    <!-- 2. foreach标签：批量插入用户 -->
    <insert id="batchInsertUsers">
        INSERT INTO user (username, age, email, status, create_time)
        VALUES
        <foreach collection="userList" item="user" separator=",">
            (
            #{user.username},
            #{user.age},
            #{user.email},
            #{user.status},
            #{user.createTime}
            )
        </foreach>
    </insert>

    <!-- 3. choose/when/otherwise：多条件动态查询（优先级匹配） -->
    <select id="selectEnableUserByCondition" resultMap="UserResultMap">
        SELECT id, username, age, enable, email, create_time
        FROM user
        WHERE enable = 1
        <choose>
            <!-- 优先级1：按用户名模糊查询 -->
            <when test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </when>
            <!-- 默认：查询所有启用状态的用户（按创建时间排序） -->
            <otherwise>
                ORDER BY create_time DESC
            </otherwise>
        </choose>
    </select>

    <!-- 4. set + if：动态更新用户（只更新非空字段） -->
    <update id="updateUserSelective">
        UPDATE user
        <set>
            <if test="username != null and username != ''">
                username = #{username},
            </if>
            <if test="phone != null">
                phone = #{phone},
            </if>
        </set>
        WHERE id = #{id}
    </update>



</mapper>


